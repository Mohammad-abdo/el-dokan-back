{
  "info": {
    "name": "Flow 5 - Vendor / Shop (بائع / متجر)",
    "description": "Ad-Dukkan Mobile - فلو البائع/المتجر: داشبورد، منتجات، طلبات، عملاء، إيرادات.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://your-domain.com" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Dashboard",
      "item": [
        { "name": "Dashboard", "request": { "method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": { "raw": "{{base_url}}/api/shop/dashboard", "host": ["{{base_url}}"], "path": ["api","shop","dashboard"] } } }
      ]
    },
    {
      "name": "Products",
      "item": [
        { "name": "List Products", "request": { "method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": { "raw": "{{base_url}}/api/shop/products", "host": ["{{base_url}}"], "path": ["api","shop","products"] } } },
        { "name": "Create Product", "request": { "method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{token}}"},{"key": "Content-Type", "value": "application/json"}], "body": { "mode": "raw", "raw": "{\"name\":\"منتج جديد\",\"price\":100,\"stock_quantity\":50,\"category_id\":1}" }, "url": { "raw": "{{base_url}}/api/shop/products", "host": ["{{base_url}}"], "path": ["api","shop","products"] } } },
        { "name": "Update Product", "request": { "method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{token}}"},{"key": "Content-Type", "value": "application/json"}], "body": { "mode": "raw", "raw": "{\"name\":\"منتج محدث\",\"price\":120}" }, "url": { "raw": "{{base_url}}/api/shop/products/1", "host": ["{{base_url}}"], "path": ["api","shop","products","1"] } } },
        { "name": "Delete Product", "request": { "method": "DELETE", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": { "raw": "{{base_url}}/api/shop/products/1", "host": ["{{base_url}}"], "path": ["api","shop","products","1"] } } }
      ]
    },
    {
      "name": "Orders & Customers",
      "item": [
        { "name": "List Orders", "request": { "method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": { "raw": "{{base_url}}/api/shop/orders", "host": ["{{base_url}}"], "path": ["api","shop","orders"] } } },
        { "name": "Order Details", "request": { "method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": { "raw": "{{base_url}}/api/shop/orders/1", "host": ["{{base_url}}"], "path": ["api","shop","orders","1"] } } },
        { "name": "Update Order Status", "request": { "method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{token}}"},{"key": "Content-Type", "value": "application/json"}], "body": { "mode": "raw", "raw": "{\"status\":\"confirmed\"}" }, "url": { "raw": "{{base_url}}/api/shop/orders/1/status", "host": ["{{base_url}}"], "path": ["api","shop","orders","1","status"] } } },
        { "name": "Customers", "request": { "method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": { "raw": "{{base_url}}/api/shop/customers", "host": ["{{base_url}}"], "path": ["api","shop","customers"] } } }
      ]
    }
  ]
}
